{
  "name": "ddevs-20/nomba-php-sdk",
  "description": "Production-grade Nomba PHP SDK",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=7.4",
    "guzzlehttp/guzzle": "^7.0",
    "monolog/monolog": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Nomba\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nomba\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  }
}